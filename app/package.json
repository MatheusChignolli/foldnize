{
  "name": "foldnize-app",
  "productName": "Foldnize",
  "version": "0.1.0",
  "private": true,
  "description": "Foldnize desktop app — Electron UI on top of the foldnize library.",
  "main": "dist/main.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build:assets": "node scripts/copy-assets.mjs",
    "build": "npm run clean && npm run build:main && npm run build:renderer && npm run build:assets",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "start": "npm run build && electron .",
    "start:fast": "electron ."
  },
  "keywords": [
    "electron",
    "files",
    "organizer",
    "rename",
    "media"
  ],
  "author": "Matheus Chignolli",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "electron": "^42.3.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "foldnize": "^1.0.0"
  }
}
